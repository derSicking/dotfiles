{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "ask",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "question": "allow",
    "todowrite": "allow",
    "websearch": "allow",
    "webfetch": "allow",
    "bash": {
      "*": "ask",
      "ls": "allow",
      "ls *": "allow",
      "find": "allow",
      "find *": "allow",
      "rg": "allow",
      "rg *": "allow",
      "grep": "allow",
      "grep *": "allow",
      "cat": "allow",
      "cat *": "allow",
      "head": "allow",
      "head *": "allow",
      "tail": "allow",
      "tail *": "allow",
      "wc": "allow",
      "wc *": "allow",
      "sort": "allow",
      "sort *": "allow",
      "uniq": "allow",
      "uniq *": "allow",
      "which": "allow",
      "which *": "allow",
      "pwd": "allow",
      "pwd *": "allow",
      "file": "allow",
      "file *": "allow",
      "du": "allow",
      "du *": "allow",
      "stat": "allow",
      "stat *": "allow",
      "readlink": "allow",
      "readlink *": "allow",
      "realpath": "allow",
      "realpath *": "allow",
      "echo": "allow",
      "echo *": "allow",
      "dirname": "allow",
      "dirname *": "allow",
      "basename": "allow",
      "basename *": "allow",
      "date": "allow",
      "date *": "allow",
      "printenv": "allow",
      "printenv *": "allow",
      "type": "allow",
      "type *": "allow",
      "git": "allow",
      "git *": "ask",
      "git describe": "allow",
      "git describe *": "allow",
      "git diff": "allow",
      "git diff *": "allow",
      "git log": "allow",
      "git log *": "allow",
      "git ls-files": "allow",
      "git ls-files *": "allow",
      "git rev-list": "allow",
      "git rev-list *": "allow",
      "git rev-parse": "allow",
      "git rev-parse *": "allow",
      "git show": "allow",
      "git show *": "allow",
      "git stash list": "allow",
      "git stash list *": "allow",
      "git status": "allow",
      "git status *": "allow",
    }
  },
  "autoupdate": "notify"
}
