{
  "$schema": "https://opencode.ai/config.json",
  "formatter": {
    "prettier": {
      "command": ["prettier", "--write", "$FILE"],
      "extensions": [
        ".js",
        ".ts",
        ".html",
        ".css",
        ".scss",
        ".json",
        ".jsonc",
        ".yaml",
      ],
    },
    "custom-markdown-formatter": {
      "command": ["prettier", "--prose-wrap=always", "--write", "$FILE"],
      "extensions": [".md"],
    },
  },
  "agent": {
    "teacher": {
      "description": "Teaches the user about the concepts and technologies used.",
      "prompt": "You are a teacher. The user is your student and wants your guidance on this project. The main goal is learning, not the product. Teach, give reading material like links to helpful websites and guide the user step by step. Do not do edits yourself unless asked, instead explain how it should be done.",
    },
  },
  "permission": {
    "*": "ask",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "question": "allow",
    "todowrite": "allow",
    "websearch": "allow",
    "webfetch": "allow",
    "bash": {
      "*": "ask",
      "ls": "allow",
      "ls *": "allow",
      "find": "allow",
      "find *": "allow",
      "rg": "allow",
      "rg *": "allow",
      "grep": "allow",
      "grep *": "allow",
      "cat": "allow",
      "cat *": "allow",
      "head": "allow",
      "head *": "allow",
      "tail": "allow",
      "tail *": "allow",
      "wc": "allow",
      "wc *": "allow",
      "sort": "allow",
      "sort *": "allow",
      "uniq": "allow",
      "uniq *": "allow",
      "which": "allow",
      "which *": "allow",
      "pwd": "allow",
      "pwd *": "allow",
      "file": "allow",
      "file *": "allow",
      "du": "allow",
      "du *": "allow",
      "stat": "allow",
      "stat *": "allow",
      "readlink": "allow",
      "readlink *": "allow",
      "realpath": "allow",
      "realpath *": "allow",
      "echo": "allow",
      "echo *": "allow",
      "dirname": "allow",
      "dirname *": "allow",
      "basename": "allow",
      "basename *": "allow",
      "date": "allow",
      "date *": "allow",
      "printenv": "allow",
      "printenv *": "allow",
      "type": "allow",
      "type *": "allow",
      "git": "allow",
      "git *": "ask",
      "git describe": "allow",
      "git describe *": "allow",
      "git diff": "allow",
      "git diff *": "allow",
      "git log": "allow",
      "git log *": "allow",
      "git ls-files": "allow",
      "git ls-files *": "allow",
      "git rev-list": "allow",
      "git rev-list *": "allow",
      "git rev-parse": "allow",
      "git rev-parse *": "allow",
      "git show": "allow",
      "git show *": "allow",
      "git stash list": "allow",
      "git stash list *": "allow",
      "git status": "allow",
      "git status *": "allow",
    },
  },
  "autoupdate": "notify",
}
