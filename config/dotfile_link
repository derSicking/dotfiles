#!/usr/bin/env bash

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )

echo "Creating symlinks for .config ($SCRIPT_DIR)"

for item in "$SCRIPT_DIR"/*; do
  base=$(basename "$item")
  # skip if target exists as a real directory (e.g. opencode/ managed by the app itself)
  [ -d "$HOME/.config/$base" ] && continue
  ln -sf "$item" "$HOME/.config/"
done

rm -f $HOME/.config/dotfile_link
